{
  "manifest_version": 3,
  "name": "Venture Signal Tracker",
  "version": "1.0.0",
  "description": "Track startups with one click and receive daily intelligence updates",
  "permissions": ["activeTab", "storage", "tabs", "alarms", "sidePanel"],
  "host_permissions": ["https://venture-signal-radar.onrender.com/*"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Venture Signal Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
